IMMICH_URL=http://your-immich-host:2283
IMMICH_API_KEY=<your-immich-api-key>
PROXY_PORT=8765
# Cap output to keep JPEGDEC decode time on the panel under the 5 s
# task-watchdog window. 800x480 + quality 78 + 4:2:0 chroma subsampling
# (handled in proxy.py) lands worst-case decode at ~1.2 s.
MAX_W=800
MAX_H=480
JPEG_QUALITY=78
RETRIES=8

# For /camera/<name> endpoint — long-lived HA token (gitignored in prod)
HA_URL=http://your-ha-host:8123
HA_TOKEN=<your-ha-long-lived-access-token>
