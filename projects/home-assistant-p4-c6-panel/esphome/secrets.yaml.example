# Copy this file to secrets.yaml and replace all values.

wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"

fallback_ap_ssid: "Guition P4 7inch Fallback"
fallback_ap_password: "CHANGE_ME_12+_CHARS"

# Generate with: openssl rand -base64 32
api_encryption_key: "REPLACE_WITH_BASE64_32_BYTE_KEY"

# Generate with: openssl rand -base64 24
ota_password: "REPLACE_WITH_OTA_PASSWORD"

# Create in Immich under Account Settings -> API Keys
immich_api_key: "REPLACE_WITH_IMMICH_API_KEY"

# URL of the local baseline-JPEG proxy (see docker/immich-proxy/).
# Run: systemctl --user start immich-proxy on the Docker host.
immich_proxy_url: "http://YOUR_DOCKER_HOST_IP:8765"